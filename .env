# ==============================
# Railway production env example
# ==============================

NODE_ENV=production
PORT=8080
PUBLIC_BASE_URL=https://faresbot-production.up.railway.app/
DEFAULT_PUBLIC_BASE_URL=https://faresbot-production.up.railway.app/
TRUST_PROXY_HOPS=1

# Telegram
BOT_TOKEN=8961523589:AAE90t5BR77HdgcJnHKPeN9XMgPgeMRVnU4
ADMIN_ID=7231690686
ADMIN_IDS=7231690686,7231690686
USE_TELEGRAM_WEBHOOK=true
TELEGRAM_WEBHOOK_PATH=/telegram/webhook

# MongoDB
MONGODB_URI=mongodb+srv://faresomarr:faresaltmimi95@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=faresbot
MONGO_CONNECT_TIMEOUT_MS=30000
STATUS_MEDIA_COLLECTION=status_media_archive
ALLOW_STATUS_MEDIA_FILE_FALLBACK=false
PRESERVE_PERSISTENT_RUNTIME_DATA=true

# HTTP hardening
SERVER_KEEP_ALIVE_TIMEOUT_MS=65000
SERVER_HEADERS_TIMEOUT_MS=66000
SERVER_REQUEST_TIMEOUT_MS=120000

# Runtime tuning
HEALTH_CHECK_INTERVAL_MS=15000
CLIENT_STALE_AFTER_MS=180000
SESSION_PING_INTERVAL_MS=25000
SESSION_MONGO_TOUCH_INTERVAL_MS=60000
SESSION_BOOT_PARALLELISM=3
MAX_PARALLEL_STATUS_JOBS_PER_PHONE=3
STATUS_EVENT_DEDUPE_TTL_MS=300000
STATUS_ARCHIVE_KEEP_PER_PHONE=120
STATUS_INTERACTION_DELAY_MS=250
AUTO_REPLY_COOLDOWN_MS=15000
PAIRING_TIMEOUT_MS=60000
RECONNECT_DELAY_MS=5000
MAX_RECONNECT_ATTEMPTS=12

# Logging
LOG_THROTTLE_WINDOW_MS=10000
LOG_THROTTLE_MAX_PER_SIGNATURE=12
LOG_THROTTLE_SUMMARY_INTERVAL_MS=30000

# Optional persistent mount if you still use local uploads elsewhere
RAILWAY_VOLUME_MOUNT_PATH=/data
BOT_STORAGE_ROOT=/data
